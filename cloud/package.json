{
  "name": "alinfc-cloud",
  "version": "1.0.0",
  "description": "支付宝 IoT 数据分析 SaaS 系统 - 云函数",
  "main": "dist/functions/gateway/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.base.json",
    "dev": "tsc -p tsconfig.base.json --watch",
    "local": "tsx server.ts",
    "start": "node dist/server.js",
    "deploy": "npm run build && tcb fn deploy gateway --envId $TCB_ENV_ID && tcb fn deploy authCallback --envId $TCB_ENV_ID && tcb fn deploy dataSync --envId $TCB_ENV_ID && tcb fn deploy initAdmin --envId $TCB_ENV_ID",
    "deploy:function": "npm run build && tcb fn deploy $FUNCTION_NAME --envId $TCB_ENV_ID",
    "logs": "tcb fn log $FUNCTION_NAME --envId $TCB_ENV_ID --tail 100",
    "invoke": "tcb fn invoke $FUNCTION_NAME --envId $TCB_ENV_ID",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "cloudbase",
    "cloudfunction",
    "alipay",
    "iot"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.1",
    "@sentry/node": "^7.109.0",
    "alipay-sdk": "^4.10.1",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "dayjs": "^1.11.10",
    "dotenv": "^17.4.0",
    "exceljs": "^4.4.0",
    "is-generator-function": "^1.1.2",
    "jsonwebtoken": "^9.0.2",
    "koa": "^3.2.0",
    "koa-bodyparser": "^4.4.1",
    "mysql2": "^3.9.2",
    "redis": "^4.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.5",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa-router": "^7.4.8",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^7.4.0",
    "@typescript-eslint/parser": "^7.4.0",
    "esbuild": "^0.27.5",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
