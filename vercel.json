{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth" },
    { "source": "/api/admin/:path*", "destination": "/api/admin" },
    { "source": "/api/tenant/:path*", "destination": "/api/tenant" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  }
}