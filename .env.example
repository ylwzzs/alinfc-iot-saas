# 支付宝 IoT 数据分析 SaaS 系统 - 环境变量配置

## 复制此文件为 .env 并填写实际值

# ====================
# 支付宝开放平台配置
# ====================

# 支付宝应用 AppID（从支付宝开放平台获取）
ALIPAY_APP_ID=2021001234567890

# 支付宝应用私钥（RSA2，PKCS8 格式）
# 生成方式：openssl genrsa -out private.pem 2048 && openssl pkcs8 -topk8 -inform PEM -outform PEM -nocrypt -in private.pem -out private_pkcs8.pem
ALIPAY_PRIVATE_KEY="MIIEvQIBADANBgkqhkiG9w0BAQEFAASC..."

# 支付宝公钥（从支付宝开放平台获取，用于验证回调签名）
ALIPAY_PUBLIC_KEY="MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ..."

# 加密算法（固定值 RSA2）
ALIPAY_ALGORITHM=RSA2

# ====================
# 支付宝授权配置
# ====================

# 授权 URL（固定值）
ALIPAY_AUTH_URL=https://openauth.alipay.com/oauth2/appToAppAuth.htm

# 授权成功后的回调地址（需在支付宝开放平台配置）
ALIPAY_REDIRECT_URI=https://your-env-id.service.tcloudbase.com/authCallback

# ====================
# MySQL 数据库配置
# ====================

# 从腾讯云 MySQL 控制台获取连接信息
DB_HOST=your-mysql-host.tencentcdb.com
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=alinfc
DB_CHARSET=utf8mb4

# ====================
# JWT 配置
# ====================

# JWT 签名密钥（至少 32 个字符，随机生成）
# 生成方式：openssl rand -base64 32
JWT_SECRET=your-random-jwt-secret-key-at-least-32-characters

# JWT 过期时间（单位：秒，7天 = 604800）
JWT_EXPIRES_IN=604800

# ====================
# 加密配置
# ====================

# 用于加密存储支付宝 Token 的 AES-256 密钥（32 字符）
# 生成方式：openssl rand -hex 16
ENCRYPT_KEY=32-char-encryption-key-here!!

# ====================
# CloudBase 配置
# ====================

# 云开发环境 ID
TCB_ENV_ID=your-env-id

# ====================
# 前端配置
# ====================

# 前端部署后的域名（用于 CORS 和重定向）
FRONTEND_URL=https://your-frontend-domain.com

# ====================
# 管理员配置
# ====================

# 默认管理员用户名
ADMIN_USERNAME=admin

# 默认管理员密码（部署后请立即修改）
ADMIN_PASSWORD=admin123

# 默认管理员姓名
ADMIN_NAME=系统管理员
